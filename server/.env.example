# ─────────────────────────────────────────────
#  Elite Jerseys — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB — get a free cluster at https://www.mongodb.com/cloud/atlas
MONGO_URI=mongodb://localhost:27017/elite-jerseys

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRE=30d

# Flutterwave (https://dashboard.flutterwave.com/settings/apis)
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxx
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxx

# Email (Gmail App Password — Google Account > Security > App Passwords)
EMAIL_FROM=your@gmail.com
EMAIL_PASSWORD=your_app_password
ADMIN_EMAIL=your@gmail.com

# Client URL (for CORS in production)
CLIENT_URL=http://localhost:5173
